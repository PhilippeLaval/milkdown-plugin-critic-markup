{
  "name": "@milkdown/plugin-critic-markup-react",
  "version": "0.1.0",
  "description": "React sidebar component for the Milkdown CriticMarkup plugin — threaded comments, accept/reject UI",
  "license": "MIT",
  "author": "Philippe Laval",
  "repository": {
    "type": "git",
    "url": "https://github.com/Philippe-Laval/milkdown-plugin-critic-markup.git",
    "directory": "packages/plugin-critic-markup-react"
  },
  "homepage": "https://github.com/Philippe-Laval/milkdown-plugin-critic-markup#readme",
  "keywords": ["milkdown", "plugin", "react", "critic-markup", "criticmarkup", "sidebar", "comments", "track-changes"],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
