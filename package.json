{
  "name": "critic-markup-milkdown",
  "private": true,
  "type": "module",
  "description": "CriticMarkup support for Milkdown — parsing, serializing, and interactive accept/reject UX",
  "license": "MIT",
  "author": "Philippe Laval",
  "repository": {
    "type": "git",
    "url": "https://github.com/Philippe-Laval/milkdown-plugin-critic-markup.git"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "vite --config e2e/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/*/src/**/*.ts",
    "typecheck": "turbo run typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@milkdown/core": ">=7.0.0",
    "@milkdown/ctx": ">=7.0.0",
    "@milkdown/preset-commonmark": ">=7.0.0",
    "@milkdown/preset-gfm": "^7.20.0",
    "@milkdown/utils": ">=7.0.0",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "mdast-util-from-markdown": "^2.0.0",
    "mdast-util-to-markdown": "^2.0.0",
    "micromark": "^4.0.2",
    "prosemirror-commands": ">=1.5.0",
    "prosemirror-model": ">=1.19.0",
    "prosemirror-state": ">=1.4.0",
    "prosemirror-transform": ">=1.7.0",
    "prosemirror-view": ">=1.31.0",
    "tsup": "^8.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.0",
    "vitest": "^1.2.0"
  },
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=18"
  }
}
